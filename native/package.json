{
  "name": "jjvs-native",
  "version": "0.0.1",
  "private": true,
  "description": "jjvs 的 napi-rs 原生绑定子项目。仅 Linux x86_64。",
  "main": "index.js",
  "napi": {
    "binaryName": "jjvs-native",
    "targets": [
      "x86_64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release --dts index.d.ts",
    "build:debug": "napi build --platform --dts index.d.ts"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2"
  }
}
