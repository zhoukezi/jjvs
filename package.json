{
  "name": "jjvs",
  "displayName": "jjvs",
  "description": "Jujutsu (jj) 版本控制系统的 Visual Studio Code 集成扩展。",
  "version": "0.0.1",
  "publisher": "zhoukz",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhoukezi/jjvs.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "keywords": [
    "jj",
    "jujutsu",
    "vcs",
    "scm"
  ],
  "activationEvents": [
    "workspaceContains:.jj"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jjvs.openFile",
        "title": "打开文件",
        "category": "Jujutsu",
        "icon": "$(go-to-file)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "jjvs.openFile",
          "when": "false"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "jjvs.openFile",
          "when": "scmProvider == jjvs && scmResourceGroup == jjvs.changes",
          "group": "inline"
        }
      ],
      "editor/title": [
        {
          "command": "jjvs.openFile",
          "when": "jjvs.diffEditorActive",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "jjvs",
      "properties": {
        "jjvs.quickDiff.mode": {
          "type": "string",
          "enum": [
            "auto",
            "enabled",
            "disabled"
          ],
          "enumDescriptions": [
            "colocated 仓库（同时含 .jj 与 .git）下禁用，避免与内置 Git 扩展的行级 diff 重叠；否则启用。",
            "无论是否 colocated，始终启用 jj 的行级 diff。",
            "始终禁用 jj 的行级 diff。"
          ],
          "default": "auto",
          "description": "编辑器侧栏（gutter）行级 diff 的启用策略。对比基准为当前 change 的第一个父 commit。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run compile",
    "compile": "tsc -p ./ && bun run build:native",
    "watch": "tsc -watch -p ./",
    "typecheck": "tsc --noEmit -p ./",
    "build:native": "cd native && bun install && bun run build",
    "build:native:debug": "cd native && bun install && bun run build:debug"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0"
  }
}
